{
  "connector.class": "io.confluent.connect.elasticsearch.ElasticsearchSinkConnector",
  "tasks.max": "1",
  "topics": "ddos-alerts",
  "connection.url": "http://elasticsearch:9200",
  "type.name": "_doc",
  "key.ignore": "true",
  "schema.ignore": "true",
  "behavior.on.null.values": "ignore",
  "write.method": "insert",
  "flush.synchronously": "true",
  "batch.size": "2000",
  "max.in.flight.requests": "1",
  "transforms": "InsertTimestamp,RouteByDate",
  "transforms.InsertTimestamp.type": "org.apache.kafka.connect.transforms.InsertField$Value",
  "transforms.InsertTimestamp.timestamp.field": "@timestamp",
  "transforms.RouteByDate.type": "org.apache.kafka.connect.transforms.TimestampRouter",
  "transforms.RouteByDate.topic.format": "ddos-alerts-${timestamp}",
  "transforms.RouteByDate.timestamp.format": "yyyy.MM.dd",
  "value.converter": "org.apache.kafka.connect.json.JsonConverter",
  "value.converter.schemas.enable": "false",
  "key.converter": "org.apache.kafka.connect.storage.StringConverter",
  "key.converter.schemas.enable": "false"
}
