{
  "uid": "ddos_dashboard",
  "title": "DDoS Realtime Dashboard",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["1s", "2s", "5s", "10s", "30s", "1m"],
    "time_options": ["5m", "15m", "30m", "1h", "3h", "6h", "12h", "24h"]
  },
  "annotations": {
    "list": []
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Traffic Overview",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Total Requests (Sum)",
      "datasource": "ddos_es",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1},
      "targets": [
        {
          "refId": "A",
          "timeField": "@timestamp",
          "query": "*",
          "metrics": [
            {"id": "1", "type": "sum", "field": "request_count"}
          ],
          "bucketAggs": [
            {"id": "2", "type": "date_histogram", "field": "@timestamp", "settings": {"interval": "auto", "min_doc_count": 0}}
          ]
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {"showLegend": true}
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Average RPS",
      "datasource": "ddos_es",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 1},
      "targets": [
        {
          "refId": "A",
          "timeField": "@timestamp",
          "query": "*",
          "metrics": [
            {"id": "1", "type": "avg", "field": "rps"}
          ],
          "bucketAggs": [
            {"id": "2", "type": "date_histogram", "field": "@timestamp", "settings": {"interval": "auto", "min_doc_count": 0}}
          ]
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": {"showLegend": true}
      }
    },
    {
      "id": 4,
      "type": "row",
      "title": "Attack Analytics",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9}
    },
    {
      "id": 5,
      "type": "barchart",
      "title": "Attack Types (Top 5)",
      "datasource": "ddos_es",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10},
      "targets": [
        {
          "refId": "A",
          "timeField": "@timestamp",
          "query": "*",
          "metrics": [
            {"id": "1", "type": "count"}
          ],
          "bucketAggs": [
            {"id": "2", "type": "terms", "field": "attack_type", "settings": {"size": 5, "order": "desc", "orderBy": "1"}}
          ]
        }
      ],
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0
      }
    },
    {
      "id": 6,
      "type": "barchart",
      "title": "Severity Distribution",
      "datasource": "ddos_es",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 10},
      "targets": [
        {
          "refId": "A",
          "timeField": "@timestamp",
          "query": "*",
          "metrics": [
            {"id": "1", "type": "count"}
          ],
          "bucketAggs": [
            {"id": "2", "type": "terms", "field": "severity", "settings": {"size": 5, "order": "desc", "orderBy": "1"}}
          ]
        }
      ],
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Critical Alerts (Last 15m)",
      "datasource": "ddos_es",
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 18},
      "targets": [
        {
          "refId": "A",
          "timeField": "@timestamp",
          "query": "severity:critical",
          "metrics": [
            {"id": "1", "type": "count"}
          ],
          "bucketAggs": []
        }
      ],
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
        "orientation": "horizontal"
      }
    },
    {
      "id": 8,
      "type": "row",
      "title": "System Health",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 24}
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Error Ratio (Avg)",
      "datasource": "ddos_es",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 25},
      "targets": [
        {
          "refId": "A",
          "timeField": "@timestamp",
          "query": "*",
          "metrics": [
            {"id": "1", "type": "avg", "field": "error_ratio"}
          ],
          "bucketAggs": [
            {"id": "2", "type": "date_histogram", "field": "@timestamp", "settings": {"interval": "auto", "min_doc_count": 0}}
          ]
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "options": {
        "legend": {"showLegend": true}
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Unique Path Count (Avg)",
      "datasource": "ddos_es",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 25},
      "targets": [
        {
          "refId": "A",
          "timeField": "@timestamp",
          "query": "*",
          "metrics": [
            {"id": "1", "type": "avg", "field": "unique_path_count"}
          ],
          "bucketAggs": [
            {"id": "2", "type": "date_histogram", "field": "@timestamp", "settings": {"interval": "auto", "min_doc_count": 0}}
          ]
        }
      ],
      "options": {
        "legend": {"showLegend": true}
      }
    },
    {
      "id": 11,
      "type": "row",
      "title": "Live Events",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 33}
    },
    {
      "id": 12,
      "type": "table",
      "title": "Recent Alerts",
      "datasource": "ddos_es",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 34},
      "targets": [
        {
          "refId": "A",
          "timeField": "@timestamp",
          "query": "*",
          "metrics": [
            {"id": "1", "type": "raw_document", "settings": {"size": 50}}
          ],
          "bucketAggs": []
        }
      ],
      "options": {
        "showHeader": true
      }
    }
  ]
}
